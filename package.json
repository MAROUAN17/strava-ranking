{
  "name": "ranking-strava",
  "version": "1.0.0",
  "private": true,
  "description": "Express server for building a ranking system with Strava activities.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:server": "nodemon src/server.js",
    "dev:client": "npm --prefix client run dev",
    "build": "npm run build:client",
    "build:client": "npm --prefix client run build",
    "preview:client": "npm --prefix client run preview",
    "start": "node src/server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
